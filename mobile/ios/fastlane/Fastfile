default_platform(:ios)

platform :ios do
  desc "Build and upload a new TestFlight build"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_filepath: ENV.fetch("APP_STORE_CONNECT_API_KEY_PATH"),
      in_house: false,
    )

    setup_ci if ENV["CI"]

    match(
      api_key: api_key,
      type: "appstore",
      readonly: true,
    )

    next_build = latest_testflight_build_number(
      api_key: api_key,
      app_identifier: "uk.towncrierapp.mobile",
      initial_build_number: 0,
    ) + 1
    UI.message("Next TestFlight build number: #{next_build}")
    File.write("build-number.txt", next_build.to_s)

    increment_build_number(
      build_number: next_build.to_s,
      xcodeproj: "TownCrier.xcodeproj",
    )

    changelog = if File.exist?("metadata/changelog.txt")
                  File.read("metadata/changelog.txt")
                else
                  "See GitHub release for changes."
                end

    # Force manual signing on the TownCrierApp target ONLY.
    # SPM library targets (Auth0, TownCrierPresentation, etc.) reject
    # provisioning profiles, so global xcargs would fail.
    # update_code_signing_settings mutates only the named targets in the
    # .xcodeproj before xcodebuild runs.
    team_id = ENV.fetch("APPLE_TEAM_ID")
    profile_specifier = "match AppStore uk.towncrierapp.mobile"

    update_code_signing_settings(
      use_automatic_signing: false,
      path: "TownCrier.xcodeproj",
      targets: ["TownCrierApp"],
      team_id: team_id,
      code_sign_identity: "Apple Distribution",
      profile_name: profile_specifier,
      bundle_identifier: "uk.towncrierapp.mobile",
    )

    build_app(
      project: "TownCrier.xcodeproj",
      scheme: "TownCrierApp",
      configuration: "Release",
      export_method: "app-store",
      output_directory: "build",
      output_name: "TownCrier.ipa",
      clean: true,
      export_options: {
        method: "app-store",
        signingStyle: "manual",
        teamID: team_id,
        provisioningProfiles: {
          "uk.towncrierapp.mobile" => profile_specifier,
        },
      },
    )

    upload_to_testflight(
      api_key: api_key,
      ipa: "build/TownCrier.ipa",
      app_identifier: "uk.towncrierapp.mobile",
      changelog: changelog,
      skip_waiting_for_build_processing: true,
      distribute_external: false,
    )
  end

  desc "Enable Associated Domains capability on the App ID (idempotent)"
  lane :enable_associated_domains do
    # One-shot ops lane. Apple Developer Portal capability changes are rare —
    # this exists so PR #363's `applinks:towncrierapp.uk` entitlement has a
    # matching capability registration on bundle ID uk.towncrierapp.mobile.
    # Run via workflow_dispatch only; do NOT wire into the beta lane.
    bundle_id = "uk.towncrierapp.mobile"

    # Spaceship needs an App Store Connect API token. Reuse the same env vars
    # the beta lane consumes so CI plumbing stays identical.
    require "spaceship"

    Spaceship::ConnectAPI.token = Spaceship::ConnectAPI::Token.from(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      filepath: File.absolute_path(ENV.fetch("APP_STORE_CONNECT_API_KEY_PATH")),
    )

    app = Spaceship::ConnectAPI::BundleId.find(bundle_id)
    UI.user_error!("Bundle ID #{bundle_id} not found in App Store Connect") if app.nil?

    capability_type = Spaceship::ConnectAPI::BundleIdCapability::Type::ASSOCIATED_DOMAINS

    already_enabled = app.get_capabilities.any? do |cap|
      cap.capability_type == capability_type
    end

    if already_enabled
      UI.success("Associated Domains capability already enabled on #{bundle_id} — no-op.")
    else
      app.create_capability(capability_type)
      UI.success("Enabled Associated Domains capability on #{bundle_id}.")
    end
  end

  desc "Force-regenerate the AppStore provisioning profile in the certs repo"
  lane :regenerate_appstore_profile do
    # Run after enable_associated_domains so the new profile picks up the
    # Associated Domains entitlement. Writes the new profile back to
    # AmyDe/town-crier-ios-certs; the beta lane's readonly: true match call
    # will then serve it on the next CD run.
    api_key = app_store_connect_api_key(
      key_id: ENV.fetch("APP_STORE_CONNECT_API_KEY_ID"),
      issuer_id: ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
      key_filepath: ENV.fetch("APP_STORE_CONNECT_API_KEY_PATH"),
      in_house: false,
    )

    setup_ci if ENV["CI"]

    match(
      api_key: api_key,
      type: "appstore",
      readonly: false,
      force: true,
    )
  end
end
