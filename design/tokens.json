{
  "$comment": "Single source of design tokens. Edit this file, run: node scripts/design-tokens/generate.mjs. ADR 0040.",
  "color": {
    "amber":            { "light": "#D4910A", "dark": "#E9A620", "oled": "#E9A620" },
    "amber-hover":      { "light": "#B87A08", "dark": "#F0B83A", "oled": "#F0B83A" },
    "amber-muted":      { "base": "amber", "alpha": 0.15 },
    "background":       { "light": "#FAF8F5", "dark": "#1A1A1E", "oled": "#000000" },
    "surface":          { "light": "#FFFFFF", "dark": "#242428", "oled": "#0A0A0A" },
    "surface-elevated": { "light": "#FFFFFF", "dark": "#2E2E33", "oled": "#161616" },
    "text-primary":     { "light": "#1C1917", "dark": "#F1EFE9", "oled": "#F1EFE9" },
    "text-secondary":   { "light": "#6B6560", "dark": "#9B9590", "oled": "#9B9590" },
    "text-tertiary":    { "light": "#A39E98", "dark": "#5C5852", "oled": "#5C5852" },
    "text-on-accent":   { "light": "#FFFFFF", "dark": "#1C1917", "oled": "#1C1917" },
    "status-permitted":  { "light": "#1A7D37", "dark": "#34C759", "oled": "#34C759" },
    "status-conditions": { "light": "#B85C00", "dark": "#FF9F0A", "oled": "#FF9F0A" },
    "status-rejected":   { "light": "#C42B2B", "dark": "#FF453A", "oled": "#FF453A" },
    "status-pending":    { "light": "#C27A0A", "dark": "#FFB340", "oled": "#FFB340" },
    "status-withdrawn":  { "light": "#7A7570", "dark": "#8E8A85", "oled": "#8E8A85" },
    "status-appealed":   { "light": "#7C3AED", "dark": "#A78BFA", "oled": "#A78BFA" },
    "border":         { "light": "#E8E4DF", "dark": "#3A3A3F", "oled": "#1E1E22" },
    "border-focused": { "base": "amber" },
    "overlay":        { "base": "#000000", "alpha": { "light": 0.4, "dark": 0.5, "oled": 0.5 } }
  },
  "statusBuckets": { "granted": "status-permitted", "refused": "status-rejected", "neutral": "status-withdrawn" },
  "shadow": {
    "card":     { "light": "0 2px 8px rgba(0, 0, 0, 0.05)",  "dark": "none", "oled": "none" },
    "elevated": { "light": "0 4px 16px rgba(0, 0, 0, 0.08)", "dark": "none", "oled": "none" }
  },
  "spacing": { "xs": 4, "sm": 8, "md": 16, "lg": 24, "xl": 32, "xxl": 48 },
  "radius":  { "sm": 8, "md": 12, "lg": 16, "full": 9999 },
  "typography": {
    "font-family": "'Inter', system-ui, -apple-system, sans-serif",
    "sizes": { "hero": "3.5rem", "display-large": "2rem", "display-small": "1.5rem", "h3": "1.25rem", "headline": "1.125rem", "body": "1rem", "caption": "0.875rem" },
    "weights": { "regular": 400, "medium": 500, "semibold": 600, "bold": 700 },
    "leadings": { "tight": 1.2, "snug": 1.25, "normal": 1.3, "relaxed": 1.4 }
  },
  "duration": { "fast": "150ms", "normal": "250ms", "slow": "400ms" },
  "layout": { "content-max-width": "1120px" }
}
